<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Students - AAMUSTED Performance Predictor</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #f5f7fb; }
        
        .navbar {
            background: linear-gradient(135deg, #1a2a3a 0%, #0f1a24 100%);
            color: white;
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }
        .logo { font-size: 1.5rem; font-weight: bold; }
        .logo span { color: #ffd700; }
        .nav-links { display: flex; gap: 1.5rem; align-items: center; flex-wrap: wrap; }
        .nav-links a { color: white; text-decoration: none; padding: 0.5rem 1rem; border-radius: 8px; }
        .nav-links a:hover, .nav-links a.active { background: rgba(255,255,255,0.2); }
        .logout-btn { background: rgba(255,80,60,0.3); border: 1px solid rgba(255,80,60,0.5); padding: 0.5rem 1rem; border-radius: 8px; cursor: pointer; }
        
        .container { max-width: 1200px; margin: 0 auto; padding: 2rem; }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
            margin-bottom: 2rem;
        }
        .stat-card {
            background: white;
            padding: 1rem;
            border-radius: 15px;
            text-align: center;
        }
        .stat-number { font-size: 2rem; font-weight: bold; color: #667eea; }
        
        .filters {
            background: white;
            padding: 1rem;
            border-radius: 15px;
            margin-bottom: 1rem;
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }
        .filter-input {
            padding: 0.5rem;
            border: 1px solid #ddd;
            border-radius: 8px;
            flex: 1;
        }
        
        .students-table {
            background: white;
            border-radius: 20px;
            overflow-x: auto;
        }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 1rem; text-align: left; border-bottom: 1px solid #eee; }
        th { background: #f8f9fa; font-weight: 600; cursor: pointer; }
        tr:hover { background: #f8f9fa; }
        
        .risk-high { color: #dc3545; font-weight: bold; }
        .risk-moderate { color: #fd7e14; }
        .risk-low { color: #28a745; }
        
        .view-btn {
            background: #667eea;
            color: white;
            border: none;
            padding: 0.3rem 0.8rem;
            border-radius: 5px;
            cursor: pointer;
        }
        
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }
        .modal-content {
            background: white;
            border-radius: 20px;
            padding: 2rem;
            max-width: 500px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
        }
        
        @media (max-width: 768px) {
            .navbar { flex-direction: column; text-align: center; }
            .filters { flex-direction: column; }
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="logo">👩‍🏫 AAMUSTED <span>Predictor</span></div>
        <div class="nav-links">
            <a href="/dashboard">Dashboard</a>
            <a href="/students" class="active">My Students</a>
            <a href="/courses">My Courses</a>
            <a href="/profile">Profile</a>
            <button class="logout-btn" onclick="logout()">🚪 Logout</button>
        </div>
    </nav>

    <div class="container">
        <div class="stats-grid" id="statsGrid"></div>
        
        <div class="filters">
            <input type="text" id="searchInput" placeholder="Search by name or index..." class="filter-input" onkeyup="filterStudents()">
            <select id="riskFilter" class="filter-input" onchange="filterStudents()">
                <option value="">All Students</option>
                <option value="high">At Risk (Critical)</option>
                <option value="moderate">At Risk (Moderate)</option>
                <option value="low">Good Standing</option>
            </select>
            <select id="programFilter" class="filter-input" onchange="filterStudents()">
                <option value="">All Programs</option>
                <option value="regular">Regular</option>
                <option value="non-regular">Non-Regular</option>
            </select>
        </div>
        
        <div class="students-table">
            <table id="studentsTable">
                <thead>
                    <tr>
                        <th onclick="sortBy('name')">Student Name</th>
                        <th onclick="sortBy('index')">Index Number</th>
                        <th onclick="sortBy('program')">Program</th>
                        <th onclick="sortBy('score')">Latest Score</th>
                        <th onclick="sortBy('status')">Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="studentsList"></tbody>
            </table>
        </div>
    </div>
    
    <div id="studentModal" class="modal">
        <div class="modal-content">
            <h3 id="modalTitle">Student Details</h3>
            <div id="modalBody"></div>
            <button onclick="closeModal()" style="margin-top: 1rem; padding: 0.5rem 1rem;">Close</button>
        </div>
    </div>

    <script>
        let allStudents = [];
        let filteredStudents = [];
        
        async function loadStudents() {
            try {
                const response = await fetch('/api/students');
                const students = await response.json();
                allStudents = students;
                filteredStudents = [...students];
                
                // Calculate stats
                const total = students.length;
                let atRiskHigh = 0, atRiskModerate = 0;
                let totalScore = 0;
                
                students.forEach(s => {
                    const score = s.latest_score || 0;
                    totalScore += score;
                    if (score < 50) atRiskHigh++;
                    else if (score < 65) atRiskModerate++;
                });
                
                document.getElementById('statsGrid').innerHTML = `
                    <div class="stat-card"><div class="stat-number">${total}</div><div>Total Students</div></div>
                    <div class="stat-card"><div class="stat-number">${atRiskHigh}</div><div>Critical Risk</div></div>
                    <div class="stat-card"><div class="stat-number">${atRiskModerate}</div><div>Moderate Risk</div></div>
                    <div class="stat-card"><div class="stat-number">${total > 0 ? (totalScore / total).toFixed(1) : 0}%</div><div>Avg Score</div></div>
                `;
                
                renderStudents();
            } catch (error) {
                console.error('Error loading students:', error);
            }
        }
        
        function renderStudents() {
            const tbody = document.getElementById('studentsList');
            tbody.innerHTML = filteredStudents.map(s => {
                const score = s.latest_score || 0;
                let statusClass = '', statusText = '';
                if (score >= 70) { statusClass = 'risk-low'; statusText = 'Good'; }
                else if (score >= 50) { statusClass = 'risk-moderate'; statusText = 'At Risk'; }
                else { statusClass = 'risk-high'; statusText = 'Critical'; }
                
                return `
                    <tr>
                        <td>${s.full_name}</td>
                        <td>${s.index_number || 'N/A'}</td>
                        <td>${s.program_type === 'regular' ? 'Regular' : 'Non-Regular'}</td>
                        <td class="${statusClass}">${score.toFixed(1)}%</td>
                        <td class="${statusClass}">${statusText}</td>
                        <td><button class="view-btn" onclick="viewStudent('${s.id}')">View</button></td>
                    </tr>
                `;
            }).join('');
        }
        
        function filterStudents() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const riskFilter = document.getElementById('riskFilter').value;
            const programFilter = document.getElementById('programFilter').value;
            
            filteredStudents = allStudents.filter(s => {
                const nameMatch = s.full_name.toLowerCase().includes(searchTerm);
                const indexMatch = (s.index_number || '').toLowerCase().includes(searchTerm);
                const searchMatch = nameMatch || indexMatch;
                
                let riskMatch = true;
                const score = s.latest_score || 0;
                if (riskFilter === 'high') riskMatch = score < 50;
                else if (riskFilter === 'moderate') riskMatch = score >= 50 && score < 70;
                else if (riskFilter === 'low') riskMatch = score >= 70;
                
                const programMatch = !programFilter || s.program_type === programFilter;
                
                return searchMatch && riskMatch && programMatch;
            });
            
            renderStudents();
        }
        
        let sortColumn = 'name';
        let sortDirection = 'asc';
        
        function sortBy(column) {
            if (sortColumn === column) {
                sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
            } else {
                sortColumn = column;
                sortDirection = 'asc';
            }
            
            filteredStudents.sort((a, b) => {
                let aVal, bVal;
                if (column === 'name') { aVal = a.full_name; bVal = b.full_name; }
                else if (column === 'index') { aVal = a.index_number || ''; bVal = b.index_number || ''; }
                else if (column === 'program') { aVal = a.program_type; bVal = b.program_type; }
                else if (column === 'score') { aVal = a.latest_score || 0; bVal = b.latest_score || 0; }
                else if (column === 'status') {
                    const scoreA = a.latest_score || 0;
                    const scoreB = b.latest_score || 0;
                    aVal = scoreA >= 70 ? 3 : (scoreA >= 50 ? 2 : 1);
                    bVal = scoreB >= 70 ? 3 : (scoreB >= 50 ? 2 : 1);
                }
                
                if (aVal < bVal) return sortDirection === 'asc' ? -1 : 1;
                if (aVal > bVal) return sortDirection === 'asc' ? 1 : -1;
                return 0;
            });
            
            renderStudents();
        }
        
        async function viewStudent(studentId) {
            try {
                const response = await fetch(`/api/student/${studentId}`);
                const data = await response.json();
                
                document.getElementById('modalTitle').innerHTML = `Student: ${data.student.name}`;
                document.getElementById('modalBody').innerHTML = `
                    <p><strong>Index Number:</strong> ${data.student.index || 'N/A'}</p>
                    <p><strong>Email:</strong> ${data.student.email}</p>
                    <p><strong>Program:</strong> ${data.student.program_type === 'regular' ? 'Regular' : 'Non-Regular'}</p>
                    <p><strong>Department:</strong> ${data.student.department || 'N/A'}</p>
                    <p><strong>Level:</strong> ${data.student.level || 'N/A'}</p>
                    <hr>
                    <h4>Course Performance</h4>
                    ${data.courses && data.courses.length > 0 ? `
                        <table style="width: 100%; margin-top: 0.5rem;">
                            <tr><th>Course</th><th>Predicted Grade</th><th>Score</th></tr>
                            ${data.courses.map(c => `
                                <tr><td>${c.code} ${c.name}</td><td>${c.predicted_grade || 'Pending'}</td><td>${c.weighted_score?.toFixed(1) || 'N/A'}%</td></tr>
                            `).join('')}
                        </table>
                    ` : '<p>No course data available.</p>'}
                    <button onclick="predictForStudent('${studentId}')" style="margin-top: 1rem; background: #667eea; color: white; border: none; padding: 0.5rem 1rem; border-radius: 5px;">Predict Student Performance</button>
                `;
                
                document.getElementById('studentModal').style.display = 'flex';
            } catch (error) {
                console.error('Error viewing student:', error);
            }
        }
        
        function predictForStudent(studentId) {
            window.location.href = `/predictor?student=${studentId}`;
        }
        
        function closeModal() {
            document.getElementById('studentModal').style.display = 'none';
        }
        
        async function logout() {
            await fetch('/api/logout', { method: 'POST' });
            window.location.href = '/';
        }
        
        loadStudents();
    </script>
</body>
</html>